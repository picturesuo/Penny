# Database
DATABASE_URL=                    # Required. Current app uses Prisma + SQLite by default; set your deployment database URL here.
DATABASE_POOL_MIN=2              # Optional. Placeholder for pooled deployments; not used by the current SQLite adapter.
DATABASE_POOL_MAX=10             # Optional. Placeholder for pooled deployments; not used by the current SQLite adapter.
SQLITE_BUSY_TIMEOUT_MS=10000     # Optional. Database lock wait time in milliseconds for the local SQLite adapter.

# Auth
NEXTAUTH_SECRET=                 # Required. Random 32+ char string.
NEXTAUTH_URL=                    # Required. Full URL of the app.

# AI providers
OPENAI_API_KEY=                  # Optional. Legacy placeholder; not used by the new provider-agnostic service layer.
ANTHROPIC_API_KEY=               # Required for deeper critique and teach-back evaluation tasks.
ANTHROPIC_BASE_URL=              # Optional. Defaults to https://api.anthropic.com/v1
ANTHROPIC_DEEP_MODEL=            # Optional. Defaults to claude-sonnet-4-0
ANTHROPIC_CHALLENGE_MODEL=       # Optional. Challenge critique policy default; current official Sonnet API ID example: claude-sonnet-4-20250514
XAI_API_KEY=                     # Required for high-volume summarization and prompt-generation tasks.
XAI_BASE_URL=                    # Optional. Defaults to https://api.x.ai/v1
XAI_HIGH_VOLUME_MODEL=           # Optional. Defaults to grok-4.20
XAI_CHALLENGE_FALLBACK_MODEL=    # Optional. Challenge critique fallback; defaults to grok-4.20
XAI_FAST_MODEL=                  # Optional. Cheap/degraded challenge or transform path; defaults to grok-4-fast
AI_PROVIDER=heuristic            # Legacy setting. Current typed AI service routes per task instead of using one global provider.

# Langfuse
LANGFUSE_PUBLIC_KEY=             # Required to emit Langfuse traces and generations.
LANGFUSE_SECRET_KEY=             # Required to emit Langfuse traces and generations.
LANGFUSE_BASE_URL=               # Optional. Defaults to Langfuse Cloud.

# Trigger.dev
TRIGGER_SECRET_KEY=              # Required to enqueue async critique jobs from the app server.
TRIGGER_PROJECT_REF=             # Required by trigger.config.ts for local dev and deploys.
TRIGGER_API_URL=                 # Optional. Set only for self-hosted Trigger.dev instances.

# Feature Flags
AI_CRITIQUE_GENERATION=false     # Set to true when Phase 1 is ready.
AI_RESPONSE_CLASSIFICATION=false
AI_STEEL_MAN_SCORING=false
AI_CLAIM_EXTRACTION=false
AI_NARRATIVE_GENERATION=false
AI_SEMANTIC_MATCHING=false

# Email (needed for notifications)
EMAIL_FROM=                      # Optional until notification system is built.
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=

# Analytics
POSTHOG_API_KEY=                 # Optional but recommended.
POSTHOG_HOST=

# Error monitoring
SENTRY_DSN=                      # Optional but recommended.
SENTRY_ENVIRONMENT=development

# App
NEXT_PUBLIC_APP_URL=             # Required. Same as NEXTAUTH_URL.
NODE_ENV=development

# Internal app secrets
CALIBRATION_TRACK_SECRET=        # Optional. Used to hash/share calibration track records.
