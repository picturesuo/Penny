{
  "name": "penny",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx packages/brain/src/server.ts",
    "build": "vite build --config packages/brain/frontend/vite.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:frontend": "vite --config packages/brain/frontend/vite.config.ts",
    "dev:api": "tsx packages/brain/src/server.ts",
    "check:launch-readiness": "node scripts/check-launch-readiness.mjs",
    "check:local-demo-readiness": "node scripts/check-local-demo-readiness.mjs",
    "check:public-readiness": "tsx scripts/check-public-readiness.ts",
    "check:public-mirror": "node scripts/check-public-mirror.mjs",
    "check:public-repo-safety": "node scripts/check-public-repo-safety.mjs",
    "check:public-repo-publish": "node scripts/check-public-repo-safety.mjs --strict",
    "check:github-deploy-secrets": "node scripts/check-github-deploy-secrets.mjs",
    "prepare:public-snapshot": "node scripts/prepare-public-snapshot.mjs",
    "publish:public-snapshot": "node scripts/publish-public-snapshot.mjs",
    "smoke:local-demo": "node scripts/smoke-local-demo.mjs",
    "smoke:public-staging": "node scripts/smoke-public-staging.mjs",
    "lint": "tsc --noEmit --pretty false && tsc --noEmit --pretty false -p packages/brain/frontend/tsconfig.json",
    "start": "tsx packages/brain/src/server.ts",
    "test": "tsx --test packages/brain/src/*.test.ts packages/brain/frontend/test/*.test.ts test/brain/nextMoveEngine.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/brain/frontend/tsconfig.json"
  },
  "dependencies": {
    "@ai-sdk/xai": "^3.0.83",
    "ai": "^6.0.168",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
