// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id                  String   @id @default(cuid())
  userId              String
  mapId               String?
  title               String
  rawIdea             String
  category            String?
  declaredIntention   String   @default("")
  intentionType       String   @default("open_exploration")
  scopedClaimIds      String   @default("[]")
  timeBudgetMinutes   Int?
  startedAt           DateTime @default(now())
  endedAt             DateTime?
  actualDurationMinutes Int?
  sessionEvents       String   @default("[]")
  closingRitual       String?
  sessionSummary      String?
  energyRating        String?
  focusRating         String?
  productivityRating  Int?
  status              String   @default("active")
  currentStage        String   @default("intake")
  questionBudget      Int      @default(5)
  clarityScore        Int      @default(18)
  extractedProblem    String?
  extractedCustomer   String?
  extractedSolution   String?
  ideaSummary         String?
  targetUser          String?
  problem             String?
  solution            String?
  assumptions         String   @default("[]")
  resolvedAssumptions String   @default("[]")
  risks               String   @default("[]")
  unknowns            String   @default("[]")
  evidenceFor         String   @default("[]")
  evidenceAgainst     String   @default("[]")
  marketPatterns      String   @default("[]")
  questionsAsked      String   @default("[]")
  answers             String   @default("[]")
  conversation        String   @default("[]")
  conceptBrief        String?
  logicOnlyMode       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ThoughtMap {
  id                     String                    @id @default(cuid())
  userId                 String
  title                  String
  rawThought             String
  status                 String                    @default("ready")
  founderBrief           String?
  founderBriefGeneratedAt DateTime?
  steelMans              String                    @default("[]")
  repairActions          String                    @default("[]")
  revisitSchedules       String                    @default("[]")
  nodes                  ThoughtNode[]
  interventions          ThoughtMapIntervention[]
  events                 ThoughtMapEvent[]
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([userId, updatedAt])
}

model ThoughtNode {
  id               String                  @id @default(cuid())
  mapId            String
  parentId         String?
  kind             String
  nodeStatus       String                  @default("active")
  actionOrigin     String?
  supersedesNodeId String?
  content          String
  note             String?
  branchOrder      Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  map              ThoughtMap              @relation(fields: [mapId], references: [id], onDelete: Cascade)
  parent           ThoughtNode?            @relation("ThoughtNodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children         ThoughtNode[]           @relation("ThoughtNodeChildren")
  supersedes       ThoughtNode?            @relation("ThoughtNodeSupersedes", fields: [supersedesNodeId], references: [id], onDelete: SetNull)
  supersededBy     ThoughtNode[]           @relation("ThoughtNodeSupersedes")
  interventions    ThoughtMapIntervention[] @relation("ThoughtNodeInterventions")
  events           ThoughtMapEvent[]       @relation("ThoughtNodeEvents")

  @@index([mapId, branchOrder])
  @@index([parentId])
  @@index([kind])
  @@index([nodeStatus])
}

model ThoughtMapIntervention {
  id            String      @id @default(cuid())
  dedupeKey     String      @unique
  mapId         String
  targetNodeId  String
  type          String
  detector      String
  triggerReason String
  prompt        String
  inputMode     String
  status        String      @default("open")
  outcomeDelta  String?
  shownAt       DateTime    @default(now())
  completedAt   DateTime?
  dismissedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  map           ThoughtMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  targetNode    ThoughtNode @relation("ThoughtNodeInterventions", fields: [targetNodeId], references: [id], onDelete: Cascade)
  events        ThoughtMapEvent[] @relation("InterventionEvents")

  @@index([mapId, status, updatedAt])
  @@index([targetNodeId, status])
}

model ThoughtMapEvent {
  id             String                 @id @default(cuid())
  mapId          String
  nodeId         String?
  interventionId String?
  eventType      String
  payload        String?
  createdAt      DateTime               @default(now())
  map            ThoughtMap             @relation(fields: [mapId], references: [id], onDelete: Cascade)
  node           ThoughtNode?           @relation("ThoughtNodeEvents", fields: [nodeId], references: [id], onDelete: SetNull)
  intervention   ThoughtMapIntervention? @relation("InterventionEvents", fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([mapId, eventType, createdAt])
  @@index([interventionId])
  @@index([nodeId])
}

model MarginFragment {
  id              String   @id @default(cuid())
  userId          String
  sourceSessionId String?
  sourceMapId     String?
  sphere          String   @default("work")
  content         String
  contextSnapshot String   @default("{}")
  status          String   @default("floating")
  priority        Float    @default(0.5)
  surfaceCount    Int      @default(0)
  lastSurfacedAt  DateTime?
  promotedAt      DateTime?
  archivedAt      DateTime?
  mergedInto      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, status, updatedAt])
  @@index([userId, sphere, updatedAt])
  @@index([sourceSessionId])
  @@index([sourceMapId])
}

model CognitiveBiasProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  profileVersion         Int      @default(1)
  biasProfileJson        String   @default("{}")
  overallCalibrationTrend String   @default("stable")
  strongestBiasId        String?
  mostImprovedBiasId     String?
  lastUpdated            DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId, updatedAt])
}

model BlindSpotMapCache {
  id               String   @id @default(cuid())
  userId           String   @unique
  blindSpotMapJson String   @default("{}")
  lastComputedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, updatedAt])
}
