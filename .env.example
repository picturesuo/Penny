# Penny local environment
#
# Copy to .env.local for local development. Do not commit .env.local.

# Required for Drizzle migrations and any database-backed API work.
DATABASE_URL=postgresql://127.0.0.1:5432/penny

# API server
NODE_ENV=development
PENNY_DEPLOY_ENV=development
PORT=3000
PENNY_API_ORIGIN=http://localhost:3000

# Development auth and CORS
PENNY_AUTH_MODE=dev
PENNY_API_TOKEN=
PENNY_SESSION_SECRET=
PENNY_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
PENNY_TRUST_AUTH_HEADERS=false

# Rate limiting
PENNY_RATE_LIMIT_MAX=120
PENNY_RATE_LIMIT_WINDOW_MS=60000
PENNY_AUTH_FAILURE_RATE_LIMIT_MAX=20
PENNY_AUTH_FAILURE_RATE_LIMIT_WINDOW_MS=60000

# Database startup
PENNY_AUTO_MIGRATE=false
PENNY_SKIP_DATABASE_PREP=false

# Structured logs are enabled by default for staging/private-alpha/production deploy envs.
PENNY_STRUCTURED_LOGS=false

# Optional live AI provider
XAI_API_KEY=
PENNY_CREATE_MODEL_BACKED=false
XAI_CREATE_OPTION_MODEL=
