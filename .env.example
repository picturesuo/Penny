# Penny local environment
#
# Copy to .env.local for local development. Do not commit .env.local.

# Required for Drizzle migrations and any database-backed API work.
DATABASE_URL=postgresql://127.0.0.1:5432/penny

# API server
NODE_ENV=development
PORT=3000
PENNY_API_ORIGIN=http://localhost:3000

# Development auth and CORS
PENNY_AUTH_MODE=dev
PENNY_API_TOKEN=
PENNY_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Rate limiting
PENNY_RATE_LIMIT_MAX=120
PENNY_RATE_LIMIT_WINDOW_MS=60000

# Optional live AI provider
XAI_API_KEY=
