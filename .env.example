# Penny local environment
#
# Copy to .env.local, edit as needed, then export before running Drizzle:
#
#   set -a
#   source .env.local
#   set +a

# Required: Postgres
DATABASE_URL=postgresql://127.0.0.1:5432/penny
DATABASE_DIRECT_URL=postgresql://127.0.0.1:5432/penny

# Local services
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_HOST=0.0.0.0
API_PORT=3001

# Optional: seeded demo identity
PENNY_SEED_USER_ID=00000000-0000-4000-8000-000000000001
PENNY_SEED_USER_EMAIL=demo@penny.local
PENNY_SEED_USER_NAME=Penny Demo

# Optional: OpenAI-backed operations
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_CAPTURE_MODEL=
OPENAI_CHALLENGE_MODEL=
OPENAI_EXTRACT_CLAIMS_MODEL=
OPENAI_BASE_URL=
MOCK_AI_MODEL=mock-demo

# Optional: Anthropic challenge provider
ANTHROPIC_API_KEY=
ANTHROPIC_CHALLENGE_MODEL=
ANTHROPIC_BASE_URL=

# Optional: xAI challenge provider
XAI_API_KEY=
XAI_CHALLENGE_MODEL=
XAI_BASE_URL=

# Optional: Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional: provider execution flags
PENNY_AUTO_GENERATE_CHALLENGE_CRITIQUE=0
PENNY_USE_PROVIDER_CHALLENGE_CRITIQUE=0

# Supabase note:
# Use pooled URL for DATABASE_URL and direct URL for DATABASE_DIRECT_URL.
# Include ?sslmode=require on both Supabase URLs.
