{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "actions": {
    "choose-codex-cockpit": {
      "type": "command",
      "title": "Choose Codex Cockpit",
      "subtitle": "Ask for project and GitHub target, then open role workspaces",
      "command": "cmux new-workspace --name 'Choose Codex Cockpit' --cwd '/Users/bensuo/Desktop/cmux-codex-launcher' --command './scripts/cmux-launcher-entry.sh --choose' --focus true",
      "target": "newTabInCurrentPane",
      "palette": true,
      "icon": {
        "type": "symbol",
        "name": "magnifyingglass.circle"
      }
    },
    "open-penny-cockpit": {
      "type": "command",
      "title": "Open Penny Cockpit",
      "subtitle": "Launch the saved Penny profile directly",
      "command": "cmux new-workspace --name 'Open Penny Cockpit' --cwd '/Users/bensuo/Desktop/cmux-codex-launcher' --command './scripts/cmux-launcher-entry.sh --profile penny' --focus true",
      "target": "newTabInCurrentPane",
      "palette": true,
      "icon": {
        "type": "symbol",
        "name": "square.stack.3d.up"
      }
    }
  },
  "ui": {
    "newWorkspace": {
      "action": "choose-codex-cockpit",
      "contextMenu": [
        {
          "action": "choose-codex-cockpit",
          "title": "Choose Codex Cockpit"
        },
        {
          "action": "open-penny-cockpit",
          "title": "Open Penny Cockpit"
        },
        {
          "type": "separator"
        },
        {
          "action": "cmux.newTerminal",
          "title": "New Terminal"
        },
        {
          "action": "cmux.newBrowser",
          "title": "New Browser"
        }
      ]
    }
  }
}
