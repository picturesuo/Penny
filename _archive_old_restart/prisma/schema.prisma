// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id                    String    @id @default(cuid())
  userId                String
  mapId                 String?
  title                 String
  rawIdea               String
  category              String?
  declaredIntention     String    @default("")
  intentionType         String    @default("open_exploration")
  scopedClaimIds        String    @default("[]")
  timeBudgetMinutes     Int?
  startedAt             DateTime  @default(now())
  endedAt               DateTime?
  actualDurationMinutes Int?
  sessionEvents         String    @default("[]")
  closingRitual         String?
  sessionSummary        String?
  energyRating          String?
  focusRating           String?
  productivityRating    Int?
  status                String    @default("active")
  currentStage          String    @default("intake")
  questionBudget        Int       @default(5)
  clarityScore          Int       @default(18)
  extractedProblem      String?
  extractedCustomer     String?
  extractedSolution     String?
  ideaSummary           String?
  targetUser            String?
  problem               String?
  solution              String?
  assumptions           String    @default("[]")
  resolvedAssumptions   String    @default("[]")
  risks                 String    @default("[]")
  unknowns              String    @default("[]")
  evidenceFor           String    @default("[]")
  evidenceAgainst       String    @default("[]")
  marketPatterns        String    @default("[]")
  questionsAsked        String    @default("[]")
  answers               String    @default("[]")
  conversation          String    @default("[]")
  conceptBrief          String?
  logicOnlyMode         Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ThoughtMap {
  id                      String                   @id @default(cuid())
  userId                  String
  title                   String
  rawThought              String
  status                  String                   @default("ready")
  founderBrief            String?
  founderBriefGeneratedAt DateTime?
  steelMans               String                   @default("[]")
  repairActions           String                   @default("[]")
  revisitSchedules        String                   @default("[]")
  nodes                   ThoughtNode[]
  interventions           ThoughtMapIntervention[]
  events                  ThoughtMapEvent[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([userId, updatedAt])
}

model ThoughtNode {
  id               String                   @id @default(cuid())
  mapId            String
  parentId         String?
  kind             String
  nodeStatus       String                   @default("active")
  actionOrigin     String?
  supersedesNodeId String?
  content          String
  note             String?
  branchOrder      Int                      @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  map              ThoughtMap               @relation(fields: [mapId], references: [id], onDelete: Cascade)
  parent           ThoughtNode?             @relation("ThoughtNodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children         ThoughtNode[]            @relation("ThoughtNodeChildren")
  supersedes       ThoughtNode?             @relation("ThoughtNodeSupersedes", fields: [supersedesNodeId], references: [id], onDelete: SetNull)
  supersededBy     ThoughtNode[]            @relation("ThoughtNodeSupersedes")
  interventions    ThoughtMapIntervention[] @relation("ThoughtNodeInterventions")
  events           ThoughtMapEvent[]        @relation("ThoughtNodeEvents")

  @@index([mapId, branchOrder])
  @@index([parentId])
  @@index([kind])
  @@index([nodeStatus])
}

model ThoughtMapIntervention {
  id            String            @id @default(cuid())
  dedupeKey     String            @unique
  mapId         String
  targetNodeId  String
  type          String
  detector      String
  triggerReason String
  prompt        String
  inputMode     String
  status        String            @default("open")
  outcomeDelta  String?
  shownAt       DateTime          @default(now())
  completedAt   DateTime?
  dismissedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  map           ThoughtMap        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  targetNode    ThoughtNode       @relation("ThoughtNodeInterventions", fields: [targetNodeId], references: [id], onDelete: Cascade)
  events        ThoughtMapEvent[] @relation("InterventionEvents")

  @@index([mapId, status, updatedAt])
  @@index([targetNodeId, status])
}

model ThoughtMapEvent {
  id             String                  @id @default(cuid())
  mapId          String
  nodeId         String?
  interventionId String?
  eventType      String
  payload        String?
  createdAt      DateTime                @default(now())
  map            ThoughtMap              @relation(fields: [mapId], references: [id], onDelete: Cascade)
  node           ThoughtNode?            @relation("ThoughtNodeEvents", fields: [nodeId], references: [id], onDelete: SetNull)
  intervention   ThoughtMapIntervention? @relation("InterventionEvents", fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([mapId, eventType, createdAt])
  @@index([interventionId])
  @@index([nodeId])
}

model MarginFragment {
  id              String    @id @default(cuid())
  userId          String
  sourceSessionId String?
  sourceMapId     String?
  sphere          String    @default("work")
  content         String
  contextSnapshot String    @default("{}")
  status          String    @default("floating")
  priority        Float     @default(0.5)
  surfaceCount    Int       @default(0)
  lastSurfacedAt  DateTime?
  promotedAt      DateTime?
  archivedAt      DateTime?
  mergedInto      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status, updatedAt])
  @@index([userId, sphere, updatedAt])
  @@index([sourceSessionId])
  @@index([sourceMapId])
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  displayName        String
  passwordHash       String
  passwordSalt       String
  emailVerifiedAt    DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  sessions           AuthSession[]
  verificationTokens EmailVerificationToken[]
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([sessionTokenHash])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
}

model CognitiveBiasProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  profileVersion          Int      @default(1)
  biasProfileJson         String   @default("{}")
  overallCalibrationTrend String   @default("stable")
  strongestBiasId         String?
  mostImprovedBiasId      String?
  lastUpdated             DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, updatedAt])
}

model BlindSpotMapCache {
  id               String   @id @default(cuid())
  userId           String   @unique
  blindSpotMapJson String   @default("{}")
  lastComputedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, updatedAt])
}

model OnboardingProgress {
  id                   String    @id @default(cuid())
  userId               String    @unique
  selectedRole         String    @default("default")
  currentStep          String    @default("welcome")
  completedStepsJson   String    @default("[]")
  firstMapId           String?
  firstClaimId         String?
  firstCritiqueRoundId String?
  skippedAt            DateTime?
  completedAt          DateTime?
  startedAt            DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId, updatedAt])
}

model BiographyAnnotation {
  id             String   @id @default(cuid())
  userId         String
  chapterId      String
  targetType     String
  targetId       String
  annotationText String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, chapterId])
  @@index([userId, targetType, targetId])
}

model FingerprintPatternReview {
  id                     String   @id @default(cuid())
  userId                 String
  patternId              String
  disputeText            String?
  falsificationCondition String?
  acknowledged           Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([userId, patternId])
  @@index([userId, updatedAt])
}

model MvpMap {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  title      String
  rawThought String   @map("raw_thought")
  status     String   @default("draft")
  claimCount Int      @default(0) @map("claim_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  claims    MvpClaim[]
  rounds    MvpDialecticRound[]
  artifacts MvpArtifact[]
  sessions  MvpThinkingSession[]
  moves     MvpMove[]

  @@index([userId], map: "idx_maps_user_id")
  @@index([status], map: "idx_maps_status")
  @@index([createdAt], map: "idx_maps_created_at")
  @@map("maps")
}

model MvpClaim {
  id                  String    @id @default(cuid())
  mapId               String    @map("map_id")
  userId              String    @map("user_id")
  text                String
  note                String?
  kind                String
  nodeStatus          String    @map("node_status")
  structureKind       String?   @map("structure_kind")
  provenance          String
  stakes              String    @default("[]")
  status              String
  confidence          Int
  confidenceHistory   String    @default("[]") @map("confidence_history")
  resolutionDate      DateTime? @map("resolution_date")
  parentClaimId       String?   @map("parent_claim_id")
  dependsOn           String    @default("[]") @map("depends_on")
  dialecticRoundCount Int       @default(0) @map("dialectic_round_count")
  lastChallengedAt    DateTime? @map("last_challenged_at")
  steelManId          String?   @unique @map("steel_man_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  map               MvpMap                        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  confidenceEntries ClaimConfidenceHistoryEntry[]
  dialecticRounds   MvpDialecticRound[]
  learningPrompts   MvpLearningPrompt[]
  moves             MvpMove[]

  @@index([userId], map: "idx_claims_user_id")
  @@index([mapId], map: "idx_claims_map_id")
  @@index([status], map: "idx_claims_status")
  @@index([createdAt], map: "idx_claims_created_at")
  @@index([parentClaimId], map: "idx_claims_parent_claim_id")
  @@map("claims")
}

model ClaimConfidenceHistoryEntry {
  id         String   @id @default(cuid())
  claimId    String   @map("claim_id")
  confidence Int
  changedAt  DateTime @map("changed_at")
  changedBy  String   @map("changed_by")
  reason     String?
  roundId    String?  @map("round_id")

  claim MvpClaim           @relation(fields: [claimId], references: [id], onDelete: Cascade)
  round MvpDialecticRound? @relation("RoundConfidenceHistoryEntries", fields: [roundId], references: [id], onDelete: SetNull)

  @@index([claimId], map: "idx_claim_confidence_history_entries_claim_id")
  @@index([roundId], map: "idx_claim_confidence_history_entries_round_id")
  @@index([changedAt], map: "idx_claim_confidence_history_entries_changed_at")
  @@map("claim_confidence_history_entries")
}

model MvpSteelMan {
  id                 String    @id @default(cuid())
  claimId            String    @map("claim_id")
  mapId              String    @map("map_id")
  userId             String    @map("user_id")
  steelManText       String    @map("steel_man_text")
  qualityScore       Float?
  qualityScoreReason String?   @map("quality_score_reason")
  usedInRound        String    @default("[]") @map("used_in_round")
  writtenAt          DateTime  @default(now()) @map("written_at")
  updatedAt          DateTime? @map("updated_at")
  updateHistory      String    @default("[]") @map("update_history")

  @@index([claimId], map: "idx_steel_mans_claim_id")
  @@index([mapId], map: "idx_steel_mans_map_id")
  @@index([userId], map: "idx_steel_mans_user_id")
  @@map("steel_mans")
}

model MvpResponseClassification {
  id           String @id @default(cuid())
  roundId      String @unique @map("round_id")
  type         String
  confidence   Int
  classifiedBy String @map("classified_by")

  round MvpDialecticRound @relation("RoundResponseClassification", fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId], map: "idx_response_classifications_round_id")
  @@map("response_classifications")
}

model MvpDialecticRound {
  id                     String    @id @default(cuid())
  userId                 String    @map("user_id")
  mapId                  String    @map("map_id")
  claimId                String?   @map("claim_id")
  roundNumber            Int       @map("round_number")
  priorRoundId           String?   @map("prior_round_id")
  critiqueGenerated      String    @map("critique_generated")
  critiqueFailureTypes   String    @default("[]") @map("critique_failure_types")
  critiqueLens           String    @map("critique_lens")
  critiqueStrength       String    @map("critique_strength")
  critiqueMode           String?   @map("critique_mode")
  voiceLabel             String?   @map("voice_label")
  userResponse           String    @map("user_response")
  confidenceAtRoundStart Int       @map("confidence_at_round_start")
  confidenceAtRoundEnd   Int       @map("confidence_at_round_end")
  confidenceDelta        Int       @map("confidence_delta")
  concessions            String    @default("[]")
  defenses               String    @default("[]")
  dismissals             String    @default("[]")
  engagementScore        Int       @map("engagement_score")
  followUpPrompt         String?   @map("follow_up_prompt")
  uncertainty            String?
  createdAt              DateTime  @default(now()) @map("created_at")
  closedAt               DateTime? @map("closed_at")

  map                    MvpMap                        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  claim                  MvpClaim?                     @relation(fields: [claimId], references: [id], onDelete: SetNull)
  responseClassification MvpResponseClassification?    @relation("RoundResponseClassification")
  confidenceEntries      ClaimConfidenceHistoryEntry[] @relation("RoundConfidenceHistoryEntries")
  learningPrompts        MvpLearningPrompt[]

  @@unique([claimId, roundNumber], map: "uq_dialectic_rounds_claim_round")
  @@index([claimId], map: "idx_dialectic_rounds_claim_id")
  @@index([userId], map: "idx_dialectic_rounds_user_id")
  @@index([mapId], map: "idx_dialectic_rounds_map_id")
  @@index([createdAt], map: "idx_dialectic_rounds_created_at")
  @@map("dialectic_rounds")
}

model MvpLearningPrompt {
  id               String    @id @default(cuid())
  claimId          String    @map("claim_id")
  roundId          String?   @map("round_id")
  userId           String    @map("user_id")
  promptType       String    @map("prompt_type")
  triggerCondition String    @map("trigger_condition")
  promptText       String    @map("prompt_text")
  userEngaged      Boolean   @map("user_engaged")
  engagedAt        DateTime? @map("engaged_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  claim MvpClaim           @relation(fields: [claimId], references: [id], onDelete: Cascade)
  round MvpDialecticRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@index([claimId], map: "idx_learning_prompts_claim_id")
  @@index([roundId], map: "idx_learning_prompts_round_id")
  @@index([userId], map: "idx_learning_prompts_user_id")
  @@map("learning_prompts")
}

model MvpArtifact {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  artifactTypeId    String   @map("artifact_type_id")
  artifactTypeName  String   @map("artifact_type_name")
  title             String
  audience          String?
  sourceMapId       String   @map("source_map_id")
  generatedAt       DateTime @map("generated_at")
  version           Int
  sectionOrder      String   @default("[]") @map("section_order")
  narrativeGlue     String?  @map("narrative_glue")
  loadBearingClaims String   @default("[]") @map("load_bearing_claims")
  dependencyHealth  String?  @map("dependency_health")
  outcomes          String   @default("[]")
  latestOutcome     String?  @map("latest_outcome")

  sourceMap MvpMap              @relation(fields: [sourceMapId], references: [id], onDelete: Cascade)
  content   MvpArtifactContent?

  @@index([userId], map: "idx_artifacts_user_id")
  @@index([sourceMapId], map: "idx_artifacts_source_map_id")
  @@index([artifactTypeId], map: "idx_artifacts_type_id")
  @@index([generatedAt], map: "idx_artifacts_generated_at")
  @@map("artifacts")
}

model MvpArtifactContent {
  id         String   @id @default(cuid())
  artifactId String   @unique @map("artifact_id")
  metadata   String   @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  artifact MvpArtifact          @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  sections MvpArtifactSection[]

  @@index([artifactId], map: "idx_artifact_contents_artifact_id")
  @@map("artifact_contents")
}

model MvpArtifactSection {
  id                String  @id @default(cuid())
  artifactContentId String  @map("artifact_content_id")
  title             String
  body              String
  claimIds          String  @default("[]") @map("claim_ids")
  sectionType       String? @map("section_type")
  position          Int     @default(0)

  artifactContent MvpArtifactContent @relation(fields: [artifactContentId], references: [id], onDelete: Cascade)

  @@index([artifactContentId], map: "idx_artifact_sections_artifact_content_id")
  @@index([artifactContentId, position], map: "idx_artifact_sections_artifact_content_position")
  @@map("artifact_sections")
}

model MvpThinkingSession {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  mapId                 String?   @map("map_id")
  title                 String
  rawIdea               String    @map("raw_idea")
  category              String?
  declaredIntention     String    @map("declared_intention")
  intentionType         String    @map("intention_type")
  scopedClaimIds        String    @default("[]") @map("scoped_claim_ids")
  timeBudgetMinutes     Int?      @map("time_budget_minutes")
  startedAt             DateTime  @default(now()) @map("started_at")
  endedAt               DateTime? @map("ended_at")
  actualDurationMinutes Int?      @map("actual_duration_minutes")
  sessionEvents         String    @default("[]") @map("session_events")
  closingRitual         String?   @map("closing_ritual")
  sessionSummary        String?   @map("session_summary")
  energyRating          String?   @map("energy_rating")
  focusRating           String?   @map("focus_rating")
  productivityRating    Int?      @map("productivity_rating")
  status                String    @default("active")
  currentStage          String    @default("intake") @map("current_stage")
  questionBudget        Int       @default(5) @map("question_budget")
  clarityScore          Int       @default(18) @map("clarity_score")
  extractedProblem      String?   @map("extracted_problem")
  extractedCustomer     String?   @map("extracted_customer")
  extractedSolution     String?   @map("extracted_solution")
  ideaSummary           String?   @map("idea_summary")
  targetUser            String?   @map("target_user")
  problem               String?
  solution              String?
  assumptions           String    @default("[]")
  resolvedAssumptions   String    @default("[]") @map("resolved_assumptions")
  risks                 String    @default("[]")
  unknowns              String    @default("[]")
  evidenceFor           String    @default("[]") @map("evidence_for")
  evidenceAgainst       String    @default("[]") @map("evidence_against")
  marketPatterns        String    @default("[]") @map("market_patterns")
  questionsAsked        String    @default("[]") @map("questions_asked")
  answers               String    @default("[]")
  conversation          String    @default("[]")
  conceptBrief          String?   @map("concept_brief")
  logicOnlyMode         Boolean   @default(false) @map("logic_only_mode")
  claimsExamined        Int       @default(0) @map("claims_examined")
  claimsUpdated         Int       @default(0) @map("claims_updated")
  critiquesRun          Int       @default(0) @map("critiques_run")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  map   MvpMap?   @relation(fields: [mapId], references: [id], onDelete: SetNull)
  moves MvpMove[]

  @@index([userId], map: "idx_sessions_user_id")
  @@index([mapId], map: "idx_sessions_map_id")
  @@index([status], map: "idx_sessions_status")
  @@index([createdAt], map: "idx_sessions_created_at")
  @@map("sessions")
}

model MvpMove {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  mapId     String?  @map("map_id")
  claimId   String?  @map("claim_id")
  sessionId String?  @map("session_id")
  moveType  String   @map("move_type")
  payload   String?
  createdAt DateTime @default(now()) @map("created_at")

  map     MvpMap?             @relation(fields: [mapId], references: [id], onDelete: SetNull)
  claim   MvpClaim?           @relation(fields: [claimId], references: [id], onDelete: SetNull)
  session MvpThinkingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_moves_user_id")
  @@index([claimId], map: "idx_moves_claim_id")
  @@index([createdAt], map: "idx_moves_created_at")
  @@index([sessionId], map: "idx_moves_session_id")
  @@map("moves")
}
