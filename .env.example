#
# Supabase Postgres
# `DATABASE_URL` should be the pooled connection string your app uses at runtime.
# `DATABASE_DIRECT_URL` should be the direct connection string Drizzle Kit uses for schema work.
# Include `?sslmode=require` on both Supabase URLs.
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_HOST=0.0.0.0
API_PORT=3001

#
# AI providers
#
ANTHROPIC_API_KEY=
XAI_API_KEY=

#
# Langfuse
#
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional. Defaults to the hosted Langfuse base URL when unset.
LANGFUSE_BASE_URL=
